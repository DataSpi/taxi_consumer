# Copy to .env before running `docker compose up` (docker compose reads .env automatically).
# .env itself is gitignored — never commit real credentials.

# --- Airflow ---
AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=admin
_AIRFLOW_WWW_USER_PASSWORD=admin

# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Airflow connection to MinIO, declared as JSON via env var instead of clicking
# through the UI (see: https://airflow.apache.org/docs/apache-airflow/stable/howto/connection.html#storing-a-connection-in-environment-variables).
# conn_type "aws" reuses the S3Hook/boto3 code path; "endpoint_url" points it at
# MinIO instead of real AWS.
AIRFLOW_CONN_MINIO_DEFAULT={"conn_type":"aws","login":"minioadmin","password":"minioadmin","extra":{"endpoint_url":"http://minio:9000"}}

# --- Snowflake ---
# Fill these into your real .env (never commit real values — .env is gitignored).
# account: the identifier from your Snowflake trial URL, e.g. https://<account>.snowflakecomputing.com
#          (or the "orgname-accountname" form Snowflake now issues for new trials).
AIRFLOW_CONN_SNOWFLAKE_DEFAULT={"conn_type":"snowflake","login":"<your_snowflake_username>","password":"<your_snowflake_password>","schema":"RAW","extra":{"account":"<your_account_identifier>","warehouse":"TAXI_WH","database":"TAXI_DB","role":"SYSADMIN"}}
